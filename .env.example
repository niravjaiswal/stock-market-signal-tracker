# Copy to .env and fill in.  `python-dotenv` loads this automatically.

# Required for LLM stance analysis. Without it, a keyword-lexicon fallback is used.
ANTHROPIC_API_KEY=

# Model used for extraction + stance (any current Claude model id).
# Haiku 4.5 = cheapest ($1/$5 per 1M tok). Bump to claude-opus-4-8 for max accuracy.
TRUMP_TRACKER_MODEL=claude-haiku-4-5

# --- Source toggles (1 = on, 0 = off) ---
ENABLE_TRUTH_SOCIAL=1
ENABLE_NEWS=1
ENABLE_PRESS_CONF=1
# Heavy: watch White House YouTube Live and transcribe with Whisper.
# Requires:  pip install yt-dlp faster-whisper   and  ffmpeg on PATH.
ENABLE_LIVE_TRANSCRIPTION=0

# --- Poll intervals (seconds) ---
TRUTH_SOCIAL_INTERVAL=25
NEWS_INTERVAL=180
PRESS_CONF_INTERVAL=120

# --- Signal tuning ---
# Minimum LLM confidence to emit a BUY/SHORT (0..1).
MIN_CONFIDENCE=0.6
# Suppress repeat signals for the same ticker within this window (seconds),
# unless the stance flips.
TICKER_COOLDOWN=900

# --- Notifications ---
ENABLE_DESKTOP_NOTIFY=1

# --- White House YouTube channel (for live transcription) ---
WH_YOUTUBE_LIVE_URL=https://www.youtube.com/@WhiteHouse/live
